server {
    listen       ${NGINX_PORT};
    server_name  documentatie.plusmin.org;
    port_in_redirect off;
    
    location / {
        absolute_redirect off;  
        root   /usr/share/nginx/html;
        index  index.html;
        error_page 404 /404.html;
    }

    location = /404.html {
        root   /usr/share/nginx/html;
        internal;
    }
}